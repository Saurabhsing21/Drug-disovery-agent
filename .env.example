# Required for summary generation
OPENAI_API_KEY=
GOOGLE_API_KEY=
# GEMINI_API_KEY=   # Optional alias for GOOGLE_API_KEY

# Required for saved runs (compare report)
# Example: postgres://user:password@localhost:5432/drugagent
DATABASE_URL=

# System provider selection (recommended; OpenAI-first probe when set to auto)
# auto|openai|google
A4T_SYSTEM_LLM_PROVIDER=auto
# Startup probe knobs
# A4T_PROVIDER_PROBE_TIMEOUT_S=6
# A4T_PROVIDER_LOCK_STRICT=1

# Optional: system-wide defaults (applied once at agents import)
# If you set these, you typically don't need to touch the per-provider model vars below.
# A4T_SYSTEM_LLM_PROVIDER=openai
# A4T_SYSTEM_REASONING_MODEL=gpt-5
# A4T_SYSTEM_FAST_MODEL=gpt-5-mini
# A4T_ENV_PROFILE=dev

# Optional: model overrides / fallbacks
# A4T_GOOGLE_REASONING_MODEL=gemini-2.5-flash
# A4T_GOOGLE_FAST_MODEL=gemini-2.5-flash
# A4T_GOOGLE_FALLBACK_MODELS=gemini-2.5-flash
# A4T_OPENAI_REASONING_MODEL=gpt-5
# A4T_OPENAI_FAST_MODEL=gpt-5-mini
# A4T_OPENAI_FALLBACK_MODELS=
# A4T_LLM_FALLBACK_ENABLED=1

# Optional: disable outbound LLM calls (use deterministic fallbacks)
# A4T_LLM_CALLS_ENABLED=1

# Optional: allow cross-provider fallback when A4T_LLM_PROVIDER is forced
# A4T_LLM_CROSS_PROVIDER_FALLBACK=0

# Optional: retry timeouts (free-tier providers can stall intermittently)
# A4T_LLM_RETRY_ATTEMPTS=3
# A4T_LLM_RETRY_BASE_DELAY_S=1.0

# Optional: global rate limiting (useful for Gemini free tier)
# A4T_LLM_CONCURRENCY=1
# A4T_LLM_MIN_INTERVAL_S=2.5
# A4T_LLM_RPM=
# A4T_LLM_429_BASE_DELAY_S=6.0
# A4T_LLM_429_MAX_DELAY_S=60.0

# Optional: allow supervisor to force a human review even when A4T_REQUIRE_REVIEW=0
# A4T_SUPERVISOR_FORCE_REVIEW=0

# Optional: human-in-the-loop gates (UI defaults disable these)
# A4T_REQUIRE_REVIEW=1
# A4T_REQUIRE_PLAN_APPROVAL=0

# Optional runtime overrides
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO
