FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# System deps: keep minimal runtime footprint.
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Copy repo (excluding via .dockerignore).
COPY . /app

# Automated DepMap dataset download during build (Ensures the server has data out-of-box).
RUN python3 scripts/download_depmap.py || echo "Warning: DepMap download failed during build."

EXPOSE 8000

CMD ["uvicorn", "ui_api.app:app", "--host", "0.0.0.0", "--port", "8000"]
