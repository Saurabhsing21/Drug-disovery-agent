# Required (choose one provider)
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Optional: pin provider
# A4T_LLM_PROVIDER=openai

# Optional: where artifacts persist inside the api container
# (compose mounts this as a named volume)
A4T_ARTIFACT_DIR=/data/artifacts

# Optional: report format (UI default is compiler)
# A4T_REPORT_FORMAT=compiler

